
## Setup Everything from Scratch
# Authenticate with GCP
gcloud auth login

# deploy terraform

cd terraform/environments/dev
terraform apply

# Set the project
gcloud config set project lendo-dr-417012

# Get GKE credentials
gcloud container clusters get-credentials lendo-app-gke-cluster \
  --region us-central1

# Create Namespaces
kubectl create namespace ingress-nginx
kubectl create namespace argocd
kubectl create namespace mlflow
kubectl create namespace monitoring
kubectl create namespace application

# Add Helm Repositories
helm repo add bitnami https://charts.bitnami.com/bitnami
helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
helm repo add argo https://argoproj.github.io/argo-helm

# Update Helm Repositories
helm repo update

# Install Ingress NGINX
helm install ingress-nginx ingress-nginx/ingress-nginx \
  --namespace ingress-nginx

# Install ArgoCD
helm install argocd argo/argo-cd \
  --namespace argocd
# ##################################

# Ingress setup for Argocd
helm upgrade argocd argo/argo-cd \
  -n argocd \
  --reuse-values \
  --set server.extraArgs="{--insecure}"
kubectl apply -f kubernetes/infrastructure/ingress/argocd-ingress.yaml

# Setup service account and secret
mkdir -p secrets

gcloud iam service-accounts keys create \
./secrets/mlflow-sa-key.json \
--iam-account=lendo-app-service-account@lendo-dr-417012.iam.gserviceaccount.com

gcloud projects add-iam-policy-binding lendo-dr-417012 \
  --member="serviceAccount:lendo-app-service-account@lendo-dr-417012.iam.gserviceaccount.com" \
  --role="roles/artifactregistry.reader"

kubectl create secret generic gcp-service-account \
--from-file=key.json=./secrets/mlflow-sa-key.json \
-n mlflow

# ###################################

# Deploy app of apps application file
kubectl apply -f kubernetes/bootstrap/root-application.yaml


# Get ArgoCD Initial Admin Password
kubectl -n argocd get secret argocd-initial-admin-secret \
  -o jsonpath="{.data.password}" | base64 -d

# Port Forward ArgoCD
kubectl port-forward svc/argocd-server -n argocd 8080:443

### Core components and project setup completed



# Setup mlflow
cd platform
sudo docker build -t us-central1-docker.pkg.dev/lendo-dr-417012/lendo-app-artifact-repo/mlflow:1.0 ./mlflow
gcloud auth configure-docker us-central1-docker.pkg.dev
docker push us-central1-docker.pkg.dev/lendo-dr-417012/lendo-app-artifact-repo/mlflow:1.0








