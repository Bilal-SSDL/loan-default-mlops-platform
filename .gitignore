datasets/

# ---- Secrets ----
# Service-account keys and other credentials must never be committed
secrets/

# ---- Terraform ----

# Local .terraform directories (provider binaries, module cache)
**/.terraform/*

# State files (may contain secrets; managed by the remote backend)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files - likely to contain sensitive / environment-specific data
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config and plan output
.terraformrc
terraform.rc
*.tfplan

# NOTE: .terraform.lock.hcl is intentionally NOT ignored - it should be committed.

# ---- Python ----

# Environment variable files (may contain credentials / config)
.env
*.env

# Virtual environments
.venv/
venv/

# Byte-compiled / cache
__pycache__/
*.py[cod]

# ---- ML data & serialized artifacts ----
# Raw/processed datasets and pickled models are large and regenerated by the
# pipeline (preprocess.py); keep them out of git. .gitkeep files preserve the
# directory structure.
ml/data/raw/*.csv
ml/data/processed/*.csv
ml/**/*.pkl

# Generated model outputs & evaluation artifacts (produced by train/evaluate and
# logged to MLflow). Keep only the directory placeholders, not the outputs.
ml/models/*
!ml/models/.gitkeep
ml/artifacts/*
!ml/artifacts/.gitkeep

# Local MLflow runs / backend store
mlruns/
mlflow.db

# Scratch / smoke-test scripts (never committed)
*_smoke.py
